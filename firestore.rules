rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token != null && 'email' in request.auth.token && (request.auth.token.email == 'info.shorif0000@gmail.com' || request.auth.token.email == 'geminiprozksi@gmail.com')) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- VALIDATION HELPERS ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.fullName is string && data.fullName.size() <= 100 &&
             data.role in ['donor', 'receiver', 'both'] &&
             data.profileCompleted is bool;
    }

    function isValidDonorPost(data) {
      return data.userId is string &&
             data.name is string && data.name.size() <= 100 &&
             data.bloodGroup is string &&
             data.district is string && data.upazila is string &&
             data.phone is string && data.phone.size() <= 20;
    }

    function isValidBloodRequest(data) {
      return data.userId is string &&
             data.patientName is string && data.patientName.size() <= 100 &&
             data.bloodGroup is string &&
             data.hospitalName is string && data.hospitalName.size() <= 200 &&
             data.district is string && data.upazila is string &&
             data.phone is string && data.phone.size() <= 20 &&
             data.status in ['open', 'pending', 'accepted', 'completed', 'cancelled'];
    }

    function isValidDirectRequest(data) {
      return data.requesterId is string && data.donorId is string &&
             data.bloodGroup is string && data.status in ['pending', 'accepted', 'cancelled', 'completed'];
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.title is string && data.message is string &&
             data.read is bool;
    }

    function isValidDonationHistory(data) {
      return data.donorId is string &&
             data.recipientName is string && data.recipientName.size() <= 100;
    }

    function isValidReport(data) {
      return data.reporterId is string && data.reportedUserId is string &&
             data.reason in ['ভুয়া তথ্য', 'ভুল মোবাইল নম্বর', 'প্রতারণার সন্দেহ', 'অশোভন আচরণ', 'অন্যান্য'] &&
             data.status in ['pending', 'closed'];
    }

    // FEEDBACK
    function isValidFeedback(data) {
      return data.userId is string &&
             data.type in ['issue', 'feedback', 'suggestion'] &&
             data.message is string && data.message.size() <= 1000;
    }

    function isValidAnnouncement(data) {
      return data.message is string && data.active is bool;
    }

    function isValidSupportMessage(data) {
      return data.name is string && data.phone is string &&
             data.subject is string && data.message is string;
    }

    function isValidHospital(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.division is string && data.district is string && data.upazila is string &&
             data.verified is bool;
    }

    function isValidVolunteer(data) {
      return data.name is string && data.name.size() <= 200 &&
             data.phone is string && data.phone.size() <= 20 &&
             data.division is string && data.district is string && data.upazila is string &&
             data.availableTime is string && data.transportAvailable is bool;
    }

    function isValidAdminLog(data) {
      return data.adminId is string && data.adminName is string &&
             data.action is string && data.targetUserId is string &&
             data.details is string;
    }

    // --- COLLECTION RULES ---

    // USERS COLLECTION
    match /users/{userId} {
      allow read: if true; // Public read allows guest search of donors on homepage & signup verification
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (incoming().isAdmin == false || (request.auth.token != null && 'email' in request.auth.token && (request.auth.token.email == 'info.shorif0000@gmail.com' || request.auth.token.email == 'geminiprozksi@gmail.com')));
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && isValidUser(incoming()) && (
          // Standard user update: cannot modify isAdmin, blocked, banned
          incoming().isAdmin == existing().isAdmin &&
          incoming().blocked == existing().blocked &&
          incoming().banned == existing().banned
        ))
      );
      allow delete: if isAdmin();
    }

    // DONOR POSTS
    match /donor_posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidDonorPost(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().userId) && isOwner(incoming().userId) && isValidDonorPost(incoming()))
      );
      allow delete: if isSignedIn() && (isAdmin() || isOwner(existing().userId));
    }

    // BLOOD REQUESTS
    match /blood_requests/{requestId} {
      allow read: if true; // Public read allows guest users to see requests on homepage
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidBloodRequest(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().userId) && isOwner(incoming().userId) && isValidBloodRequest(incoming()))
      );
      allow delete: if isSignedIn() && (isAdmin() || isOwner(existing().userId));
    }

    // DIRECT REQUESTS
    match /direct_requests/{requestId} {
      allow read: if isSignedIn() && (isOwner(resource.data.requesterId) || isOwner(resource.data.donorId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().requesterId) && isValidDirectRequest(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (isOwner(existing().donorId) && incoming().requesterId == existing().requesterId && incoming().donorId == existing().donorId && isValidDirectRequest(incoming())) ||
        (isOwner(existing().requesterId) && incoming().requesterId == existing().requesterId && incoming().donorId == existing().donorId && isValidDirectRequest(incoming()))
      );
      allow delete: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin()) && isValidNotification(incoming());
      allow delete: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
    }

    // DONATION HISTORY
    match /donation_history/{historyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().donorId) && isValidDonationHistory(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // REPORTS
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isOwner(incoming().reporterId) && isValidReport(incoming());
      allow update: if isAdmin() && isValidReport(incoming());
      allow delete: if isAdmin();
    }

    // FEEDBACK
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidFeedback(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ANNOUNCEMENTS
    match /announcements/{announcementId} {
      allow read: if true; // Public announcements
      allow write: if isAdmin() && isValidAnnouncement(incoming());
    }

    // BANNED PHONE NUMBERS
    match /banned_phone_numbers/{phone} {
      allow read: if true; // Let client check if their phone is banned during signup
      allow write: if isAdmin();
    }

    // SETTINGS
    match /settings/{settingId} {
      allow read: if true; // Let global settings load on page mount (e.g. maintenance mode, registration status)
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ADMINS
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // SUPPORT MESSAGES
    match /support_messages/{messageId} {
      allow read: if isAdmin();
      allow create: if true; // Guest users should be able to contact admin support
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // HOSPITALS DIRECTORY
    match /hospitals/{hospitalId} {
      allow read: if true; // Public read on directory page
      allow create: if true; // Guest users can submit new hospital entries for admin approval
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // VOLUNTEERS DIRECTORY
    match /volunteers/{volunteerId} {
      allow read: if true; // Public read on directory page
      allow create: if true; // Anyone can sign up as volunteer
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ADMIN LOGS
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // COMPLETED DONATIONS
    match /completed_donations/{donationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // OTP VERIFICATIONS (Server-only or System Backend)
    match /otp_verifications/{phone} {
      allow read, write: if request.auth != null && request.auth.token.email == "system-backend@donateblood.com";
    }

    // OTP REQUESTS LOG (Server-only or System Backend)
    match /otp_requests_log/{logId} {
      allow read, write: if request.auth != null && request.auth.token.email == "system-backend@donateblood.com";
    }
  }
}
